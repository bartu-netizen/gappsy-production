{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.js && node scripts/generate-og-images.js && vite build && node scripts/write-build-id.js && node scripts/scan-forbidden-keywords.js && node scripts/verify-seo-prerender.mjs && node scripts/verify-seo-indexability.js && node scripts/verify-seo-tools.mjs",
    "scan-content": "node scripts/scan-forbidden-keywords.js",
    "build:verify": "npm run build && bash scripts/verify-prerendered-files.sh",
    "build:quick": "vite build",
    "generate-og": "node scripts/generate-og-images.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "prerender": "node scripts/prerender.js",
    "verify-seo": "bash scripts/verify-prerendered-html.sh",
    "verify-files": "bash scripts/verify-prerendered-files.sh",
    "verify-crawlers": "bash scripts/verify-crawler-access.sh",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@types/nodemailer": "^7.0.5",
    "lucide-react": "^0.344.0",
    "nodemailer": "^7.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@netlify/functions": "^5.1.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}

# Cache-Control and compression headers for optimal performance
# Order matters: more specific rules first, then general rules

# SEO CRITICAL FILES - Robots.txt and Sitemap.xml
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex

# FAVICON FILES - Long-term caching for branding
/favicon.ico
  Content-Type: image/x-icon
  Cache-Control: public, max-age=31536000, immutable

/favicon-32x32.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/favicon-16x16.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/apple-touch-icon.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

# PRIVATE/SENSITIVE PAGES - No caching, no indexing
/availability/*
  Cache-Control: no-store, private
  X-Robots-Tag: noindex, nofollow
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

/admin/*
  Cache-Control: no-store, private
  X-Robots-Tag: noindex, nofollow
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

/login
